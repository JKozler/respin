{
	"name": "mioweb-cz/http-client",
	"description": "Library for making HTTP requests.",
	"type": "library",
	"license": "proprietary",
	"authors": [
		{
			"name": "Jan-Sebastian Fabík",
			"email": "honza@fabik.org"
		},
		{
			"name": "Jiří Slischka",
			"email": "slischkaj@gmail.com"
		},
		{
			"name": "Matouš Němec"
		},
		{
			"name": "Adam Zelycz",
			"email": "adam.zelycz@mioweb.cz"
		}
	],
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"ext-curl": "*",
		"nette/tester": "^1.5",
		"guzzlehttp/guzzle": "^6.0 || ^7.0",
		"tracy/tracy": "^2.6",
		"react/http": "^0.4.1",
		"react/child-process": "^0.4.0",
		"nette/di": "^2.3",
		"phpstan/phpstan": "^0.12.81",
		"phpstan/phpstan-strict-rules": "^0.12.9",
		"nette/http": "^2.4",
		"mioweb-cz/coding-standard": "^1.0.1",
		"mioweb-cz/utils": "^1.0.0"
	},
	"suggest": {
		"ext-curl": "to use class CurlHttpClient",
		"guzzlehttp/guzzle": "to use class GuzzleHttpClient",
		"tracy/tracy": "to use class LoggingHttpClient",
		"nette/http": "to use class LoggingHttpClient",
		"nette/tester": "to use class CapturingHttpClient",
		"nette/di": "to use class HttpClientExtension"
	},
	"config": {
		"platform": {
			"php": "7.4"
		}
	},
	"repositories": [
		{
			"type": "vcs",
			"url": "git@github.com:mioweb-cz/coding-standard.git"
		},
		{
			"type": "vcs",
			"url": "git@github.com:mioweb-cz/utils.git"
		}
	],
	"autoload": {
		"psr-4": {
			"": [
				"src/",
				"tests/"
			]
		}
	}
}
