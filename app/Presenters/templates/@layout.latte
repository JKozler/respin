        <div class="contact-info">
            <span>📞 <a style="color: white;text-decoration: none !important;" href="tel:+420736127540">736 127 540</a></span>
            <span>✉ <a style="color: white;text-decoration: none !important;" href="mailto:vyroba@respinteam.cz">vyroba@respinteam.cz</a></span>
