                    </div>
                    <div class="dropdown-item">
                        <a n:href="Home:services#hotel" class="dropdown-link">Vřetenový hotel</a>
                    </div>
                    <div class="dropdown-item">
                        <a n:href="Home:services#vyvazovani" class="dropdown-link">Vyvažování</a>
                    </div>
                </div>
            </li>
            
            <!-- Podpora - s dropdown menu -->
            <li class="nav-item">
                <a n:href="Home:support" class="nav-link">Podpora</a>
                <div class="dropdown">
                    <div class="dropdown-item">
                        <a n:href="Home:support#faq" class="dropdown-link">FAQ</a>
                    </div>
                    <div class="dropdown-item">
                        <a n:href="Home:support#reseni" class="dropdown-link">Řešení potíží</a>
                    </div>
                    <div class="dropdown-item">
