{block content}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Upravit obrázek: {$image->title}</h1>
    <a n:href="Admin:images" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Zpět
    </a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                {form imageForm}
                    {input category_id value => $image->category_id}
                    {input title value => $image->title}
                    {input description value => $image->description}
                    {input alt_text value => $image->alt_text}
                    {input sort_order value => $image->sort_order}
                    {input active value => $image->active}
                    
                    <div class="mb-3">
                        {label category_id  /}
                        {input category_id }
                    </div>
                    <div class="mb-3">
                        {label title  /}
                        {input title }
                    </div>
                    <div class="mb-3">
                        {label description  /}
                        {input description }
                    </div>
                    <div class="mb-3">
                        {label alt_text  /}
                        {input alt_text }
                    </div>
                    <div class="mb-3">
                        <label>Současný obrázek:</label>
                        <div>
                            <img src="/uploads/gallery/{$image->filename}" 
                                 alt="{$image->alt_text}" 
                                 class="img-thumbnail" 
                                 style="max-width: 200px;">
                        </div>
                    </div>
                    <div class="mb-3">
                        {label image  /}
                        {input image }
                        <div class="form-text">Ponechte prázdné, pokud nechcete měnit obrázek</div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {label sort_order  /}
                            {input sort_order }
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check mt-4">
                                {input active }
                                {label active  /}
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        {input save }
                    </div>
                {/form}
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6>Informace o obrázku</h6>
            </div>
            <div class="card-body">
                <p><strong>Název souboru:</strong> {$image->filename}</p>
                <p><strong>Původní název:</strong> {$image->original_name}</p>
                <p><strong>Vytvořeno:</strong> {$image->created_at|date:'d.m.Y H:i'}</p>
            </div>
        </div>
    </div>
</div>